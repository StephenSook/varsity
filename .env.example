# VARSITY environment template. Copy to .env and fill with real values. Never commit .env.

# Live match triggers (paid tiers needed for World Cup coverage)
SPORTMONKS_API_KEY=your_sportmonks_key_here
API_FOOTBALL_KEY=your_api_football_key_here

# IBM watsonx (server-tier Granite + Granite Guardian)
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite model ids (pin exact ids in infra/VERSIONS.lock)
GRANITE_MODEL_ID=ibm/granite-4-0-h-small
GRANITE_GUARDIAN_MODEL_ID=ibm/granite-guardian-4

# Context Forge gateway
CONTEXT_FORGE_URL=http://localhost:4444
CONTEXT_FORGE_JWT_SECRET=change_me_min_32_chars
CONTEXT_FORGE_ADMIN_EMAIL=admin@example.com
CONTEXT_FORGE_ADMIN_PASSWORD=change_me_strong

# Backend
BACKEND_URL=http://localhost:8000
